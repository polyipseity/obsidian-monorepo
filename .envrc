# direnv configuration for obsidian-monorepo
#
# Injects a bun wrapper that hides the workspace root package.json when bun
# is invoked from a subdirectory. This prevents bun install from treating the
# subdirectory as a workspace member and writing to the root lockfile.
#
# MANUAL RESTORE: if bun is interrupted by SIGKILL and package.json.bak is
# left behind, run from anywhere in the repo:
#   bun-workspace-restore
# or directly:
#   mv "${_workspace_root}/package.json.bak" "${_workspace_root}/package.json"

_workspace_root="$(pwd)"
_bin_dir="$(direnv_layout_dir)/bin"
_real_bun="$(command -v bun 2>/dev/null)"

if [[ -z "$_real_bun" ]]; then
    log_error "direnv: bun not found in PATH; run 'direnv reload' after installing bun"
    return 1
fi

mkdir -p "$_bin_dir"

# bun wrapper: hides workspace root package.json in subdirectory invocations.
# NOTE: if bun is reinstalled or updated to a different path, run 'direnv reload'.
cat > "$_bin_dir/bun" << EOF
#!/usr/bin/env bash
# direnv bun wrapper — auto-generated by .envrc at ${_workspace_root}
# Do not edit; regenerated on 'direnv reload'.
ROOT_PKG="${_workspace_root}/package.json"
BAK_PKG="\${ROOT_PKG}.bak"
_did_rename=0

if [[ "\$(pwd)" != "${_workspace_root}" ]]; then
    if [[ -f "\$BAK_PKG" ]]; then
        echo "direnv-bun: '\$BAK_PKG' exists; a previous bun run may have been interrupted." >&2
        echo "direnv-bun: run 'bun-workspace-restore' or: mv '\$BAK_PKG' '\$ROOT_PKG'" >&2
    elif [[ -f "\$ROOT_PKG" ]]; then
        mv "\$ROOT_PKG" "\$BAK_PKG"
        _did_rename=1
        trap '[[ -f "\$BAK_PKG" ]] && mv "\$BAK_PKG" "\$ROOT_PKG"' EXIT INT TERM HUP
    fi
fi

"${_real_bun}" "\$@"
_code=\$?

if [[ "\$_did_rename" -eq 1 ]]; then
    [[ -f "\$BAK_PKG" ]] && mv "\$BAK_PKG" "\$ROOT_PKG"
    trap - EXIT INT TERM HUP
fi

exit \$_code
EOF
chmod +x "$_bin_dir/bun"

# bun-workspace-restore: manually recovers from an interrupted bun run.
cat > "$_bin_dir/bun-workspace-restore" << EOF
#!/usr/bin/env bash
# Restores the workspace root package.json if it was left renamed after an
# interrupted bun run (e.g. killed with SIGKILL).
ROOT_PKG="${_workspace_root}/package.json"
BAK_PKG="\${ROOT_PKG}.bak"

if [[ -f "\$BAK_PKG" ]]; then
    mv "\$BAK_PKG" "\$ROOT_PKG" && echo "Restored: \$ROOT_PKG" || echo "Error: failed to restore" >&2
else
    echo "Nothing to restore: \$BAK_PKG does not exist"
fi
EOF
chmod +x "$_bin_dir/bun-workspace-restore"

PATH_add "$_bin_dir"
